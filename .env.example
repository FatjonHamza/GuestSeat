# PostgreSQL connection string — auto-injected by Railway, or set manually for local dev
# Local example: postgres://postgres:postgres@localhost:5432/guestseat
DATABASE_URL=

# Resend API key for sending emails (https://resend.com)
RESEND_API_KEY=

# Verified sender address in your Resend account
RESEND_FROM=

# Set to "production" on Railway — controls static serving vs Vite dev middleware
# Railway injects this automatically; set manually for local prod testing
NODE_ENV=development

# Port the server listens on — Railway injects this automatically
# Leave unset locally to use the default (3000)
PORT=
